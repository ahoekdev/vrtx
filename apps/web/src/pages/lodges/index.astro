---
export const prerender = false;

import { getLodges } from "../../data/getLodges";
import BaseLayout from "../../layouts/BaseLayout.astro";

const { data, error } = await getLodges();
---

<BaseLayout title="Lodges">
  <h1>Lodges</h1>

  {
    error ? (
      <p>Unable to load lodges right now.</p>
    ) : data.length === 0 ? (
      <p>No lodges found.</p>
    ) : (
      <ul>
        {data.map((lodge) => (
          <li>
            <strong>{lodge.name}</strong> <span>{lodge.country}</span>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
