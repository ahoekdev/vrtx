---
export const prerender = false;

import { actions } from "astro:actions";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { User } from "../../types/User";
import { getApiBaseUrl } from "../../utils/getApiBaseUrl";
import { Button, Input, Select } from "webcoreui/astro";

let users: User[] = [];
let usersLoadError = false;
const countryCodes = ["AT", "CH", "DE", "FR", "IT", "LI", "SI"] as const;

try {
  const usersResponse = await fetch(new URL("/users", getApiBaseUrl()));

  if (!usersResponse.ok) {
    usersLoadError = true;
  } else {
    users = (await usersResponse.json()) as User[];
  }
} catch {
  usersLoadError = true;
}

const result = Astro.getActionResult(actions.createLodge);

if (result?.data?.success) {
  return Astro.redirect("/lodges");
}

const createError = result?.data && !result.data.success
  ? result.data.message
  : result?.error
    ? "Invalid input."
    : null;
const backendFieldErrors =
  result?.data && !result.data.success && result.data.fieldErrors
    ? result.data.fieldErrors
    : {};

const countryOptions = countryCodes.map((countryCode) => ({
  name: countryCode,
  value: countryCode,
}));

const keeperOptions = users.map((user) => ({
  name: user.email,
  value: user.id,
}));
---

<BaseLayout title="Create lodge">
  <h1>Create lodge</h1>

  {usersLoadError ? (
    <p>Unable to load users right now.</p>
  ) : (
    <form method="POST" action={actions.createLodge}>
      <div>
        <Input id="name" name="name" label="Name" required />
        {backendFieldErrors.name && <p>{backendFieldErrors.name.join(", ")}</p>}
      </div>

      <div>
        <input id="country" name="country" type="hidden" required />
        <Select
          name="countrySelect"
          label="Country"
          placeholder="Select a country"
          itemGroups={[{ items: countryOptions }]}
        />
        {backendFieldErrors.country && <p>{backendFieldErrors.country.join(", ")}</p>}
      </div>

      <div>
        <input id="keeperId" name="keeperId" type="hidden" required />
        <Select
          name="keeperSelect"
          label="Keeper"
          placeholder="Select a keeper"
          itemGroups={[{ items: keeperOptions }]}
        />
        {backendFieldErrors.keeperId && <p>{backendFieldErrors.keeperId.join(", ")}</p>}
      </div>

      {createError && <p>{createError}</p>}

      <div class="actions">
        <Button href="/lodges" theme="flat">Cancel</Button>
        <Button type="submit">Create lodge</Button>
      </div>
    </form>
  )}
</BaseLayout>

<script>
  import { listen } from "webcoreui";

  listen("selectOnChange", (payload) => {
    if (payload.select === "countrySelect") {
      const input = document.getElementById("country");
      if (input instanceof HTMLInputElement) input.value = payload.value ?? "";
    }

    if (payload.select === "keeperSelect") {
      const input = document.getElementById("keeperId");
      if (input instanceof HTMLInputElement) input.value = payload.value ?? "";
    }
  });
</script>

<style>
  .actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }
</style>
